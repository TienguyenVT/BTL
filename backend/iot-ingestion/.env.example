# ==============================================================================
# IoT Ingestion Module - Environment Variables
# ==============================================================================

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=iomt_health_monitor

# MQTT Broker Configuration (VD: Mosquitto local hoặc HiveMQ Cloud)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=esp32/health/data
MQTT_CLIENT_ID=iomt-ingestion-service

# HTTP Server Configuration (backup endpoint)
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Cleaning Pipeline Configuration
CLEANING_BATCH_SIZE=50
CLEANING_INTERVAL_SECONDS=60
